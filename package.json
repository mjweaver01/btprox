{
  "name": "btprox",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot --watch src/server/index.ts",
    "start": "NODE_ENV=production bun run src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "cert:generate": "./scripts/generate-cert.sh",
    "build:client": "bun run scripts/build-client.ts",
    "cap:sync": "bun run build:client && bunx cap sync",
    "cap:ios": "bun run cap:sync && bunx cap open ios",
    "cap:android": "bun run cap:sync && bunx cap open android"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "bun-plugin-tailwind": "^0.1.2",
    "tailwindcss": "^4",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^8.1.3",
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@stoprocent/noble": "^2.3.17",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7.13.0"
  },
  "trustedDependencies": [
    "@stoprocent/bluetooth-hci-socket",
    "@stoprocent/noble"
  ]
}
